rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations
    function isValidUser(data) {
      return data.email is string && data.email.size() > 0 && data.email.size() < 256
        && (data.displayName == null || (data.displayName is string && data.displayName.size() < 128))
        && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() < 512));
    }

    function isValidMeal(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100
        && data.timestamp is number
        && data.nutrients is map
        && data.nutrients.protein is number
        && data.nutrients.carbs is number
        && data.nutrients.fiber is number
        && data.nutrients.calories is number;
    }

    function isValidMedication(data) {
      return data.medicationName is string && data.medicationName.size() > 0
        && data.dose is string && data.dose.size() > 0
        && data.timestamp is number;
    }

    function isValidSymptom(data) {
      return data.type is string && data.type.size() > 0
        && data.intensity is number && data.intensity >= 1 && data.intensity <= 5
        && data.timestamp is number;
    }

    function isValidWeight(data) {
      return data.value is number && data.value > 0
        && data.timestamp is number;
    }

    // Match Blocks
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) 
        && isValidUser(incoming())
        && incoming().email == existing().email; // Email immutable

      match /meals/{mealId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidMeal(incoming());
        allow update: if isOwner(userId) && isValidMeal(incoming());
        allow delete: if isOwner(userId);
      }

      match /medications/{medicationId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidMedication(incoming());
        allow update: if isOwner(userId) && isValidMedication(incoming());
        allow delete: if isOwner(userId);
      }

      match /symptoms/{symptomId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSymptom(incoming());
        allow update: if isOwner(userId) && isValidSymptom(incoming());
        allow delete: if isOwner(userId);
      }

      match /weights/{weightId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidWeight(incoming());
        allow update: if isOwner(userId) && isValidWeight(incoming());
        allow delete: if isOwner(userId);
      }
    }
  }
}
